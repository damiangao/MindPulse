{
  "name": "simple-chatapp-python",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "PYTHONPATH=. uv run python -m server.main",
    "dev:client": "vite --port 5173",
    "start": "PYTHONPATH=. uv run python -m server.main",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.0.0",
    "jsdom": "^29.1.1",
    "vite": "^5.4.0",
    "vitest": "^4.1.5"
  }
}
