{
  "name": "simple-chatapp-python",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "PYTHONPATH=. uv run python -m server.main",
    "dev:client": "vite --port 5173",
    "start": "PYTHONPATH=. uv run python -m server.main",
    "build": "vite build"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "vite": "^5.4.0"
  }
}
