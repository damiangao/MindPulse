# MindPulse Docker Environment Variables
# Copy this file to .env in the project root and fill in the values

# Required
ANTHROPIC_API_KEY=your_api_key_here

# Optional
ANTHROPIC_BASE_URL=https://api.minimax.io
MODEL=MiniMax-M2.7
PORT=3001
JWT_SECRET=your-secret-key-min-32-bytes-long
JWT_EXPIRE_HOURS=24
